    vec3 p_bwd = model_far(ray.pos_0, ray.dir_0, ray.lambda - eps);
    vec3 vel = normalize((p_fwd - p_bwd) / (2.0 * eps));
    ray.pos_0 = ray.pos_i;
    ray.dir_0 = vel;
    ray.lambda = 0.0;
    ray.near = true;

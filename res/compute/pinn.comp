#version 430 core

#define MAX_PLANETS 64

// 8x8 = 64 invocations per work group
layout (local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

layout(rgba8, binding = 0) uniform image2D imgOutput;

uniform float time;

layout(std140, binding = 1) uniform Camera {
    mat4 invProjectionMatrix;
    mat4 invViewMatrix;
    vec4 PosCartesian;
} camera;

layout(std140, binding = 2) uniform SimSettings {
    int maxStepCount;
    float stepSize;
    float Rs;
    float worldRadius;
    float planetAmbientLight;
} sim;

layout(std140, binding = 3) uniform DiskSettings {
    float innerRadius;
    float outerRadius;
    float height;
    int renderMode;        // 0=flat, 1=angle, 2=raymarching
    float absorptionCoeff;
    int maxMarchSteps;
    float marchStepSize;
    int useNoise;          // 0=simple colors, 1=animated noise texture
    vec4 colorHot;
    vec4 colorCool;
} disk;

layout(std140, binding = 4) uniform Planets {
    int numPlanets;
    vec4 planets[MAX_PLANETS];  // xyz = position, w = radius
} planets;

// the texture array sampler
uniform sampler2DArray planetTextureArray;

// the noise texture we use in order to give the disk "ripples"
uniform sampler2D noiseTexture;

uniform int rowOffset;

// mapping the planets to their respective textures
uniform int textureIndexMap[MAX_PLANETS];

// === PINN WEIGHTS (SSBO) ===
layout(std430, binding = 5) buffer FarWeights { float wf[]; };
layout(std430, binding = 6) buffer NearWeights { float wn[]; };

uniform float far_pos_scale;
uniform float far_lmbda_scale;
uniform float near_pos_scale;
uniform float near_lmbda_scale;
// === END PINN WEIGHTS ===

const float PI = 3.14159265;
const float HIT_THRESHOLD = 0.01f;
const int PINN_MAX_STEP_COUNT = 10;  // reduced to avoid TDR timeout
const float NEAR_FIELD_RADIUS = 10.0;  // matches R_SPLIT from training

// === PINN FORWARD PASS ===
#define PINN_INPUT_DIM 127  // 6 + 6*2*10 + 1
#define PINN_L 10

float softplus(float x) {
    if (x > 20.0) return x;
    return log(1.0 + exp(x));
}

void fourierEncode(vec3 npos, vec3 dir, float nlmbda, out float inp[PINN_INPUT_DIM]) {
    float spatial[6];
    spatial[0] = npos.x; spatial[1] = npos.y; spatial[2] = npos.z;
    spatial[3] = dir.x;  spatial[4] = dir.y;  spatial[5] = dir.z;

    for (int i = 0; i < 6; i++) inp[i] = spatial[i];

    int idx = 6;
    for (int l = 0; l < PINN_L; l++) {
        float freq = pow(2.0, float(l)) * PI;
        for (int i = 0; i < 6; i++) {
            inp[idx++] = sin(freq * spatial[i]);
            inp[idx++] = cos(freq * spatial[i]);
        }
    }
    inp[126] = nlmbda;
}

// far-field: 128 hidden, 6 layers
vec3 model_far(vec3 pos, vec3 dir, float lmbda) {
    vec3 npos = pos / far_pos_scale;
    float nlmbda = lmbda / far_lmbda_scale;

    float inp[PINN_INPUT_DIM];
    fourierEncode(npos, dir, nlmbda, inp);

    float h[128];
    int off = 0;
    for (int j = 0; j < 128; j++) {
        float sum = 0.0;
        for (int k = 0; k < PINN_INPUT_DIM; k++) {
            sum += wf[off + j * PINN_INPUT_DIM + k] * inp[k];
        }
        h[j] = softplus(sum + wf[off + 128 * PINN_INPUT_DIM + j]);
    }
    off += 128 * PINN_INPUT_DIM + 128;

    float h_new[128];
    for (int layer = 0; layer < 6; layer++) {
        for (int j = 0; j < 128; j++) {
            float sum = 0.0;
            for (int k = 0; k < 128; k++) {
                sum += wf[off + j * 128 + k] * h[k];
            }
            h_new[j] = softplus(sum + wf[off + 128 * 128 + j]) + h[j];
        }
        for (int j = 0; j < 128; j++) h[j] = h_new[j];
        off += 128 * 128 + 128;
    }

    vec3 out_pos;
    for (int j = 0; j < 3; j++) {
        float sum = 0.0;
        for (int k = 0; k < 128; k++) {
            sum += wf[off + j * 128 + k] * h[k];
        }
        out_pos[j] = sum + wf[off + 3 * 128 + j];
    }

    return (out_pos + npos) * far_pos_scale;  // skip connection: network learns correction from input pos
}

